# ── AssetEra Environment Variables ──

# OpenAI API key (required for AI Advisor page)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Snowflake credentials (required for database features)
# SNOW_ACCOUNT=your_account
# SNOW_USER=your_user
# SNOW_PASSWORD=your_password
# SNOW_ROLE=your_role
# SNOW_WAREHOUSE=your_warehouse
# SNOW_DATABASE=your_database
# SNOW_SCHEMA=your_schema
