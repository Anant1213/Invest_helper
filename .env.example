# ── AssetEra Environment Variables ──

# OpenAI API key (required for AI Advisor page)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# PostgreSQL connection string (required for DB-backed market data layer)
# Example (managed/remote Postgres):
#POSTGRES_URL=postgresql://postgres:[YOUR-PASSWORD]@db.riicxfpvjxzdndxauvnm.supabase.co:5432/postgres
# You can also use DATABASE_URL instead.
# POSTGRES_URL=

# Snowflake credentials (legacy workflow; optional unless using Snowflake deploy)
# SNOW_ACCOUNT=your_account
# SNOW_USER=your_user
# SNOW_PASSWORD=your_password
# SNOW_ROLE=your_role
# SNOW_WAREHOUSE=your_warehouse
# SNOW_DATABASE=your_database
# SNOW_SCHEMA=your_schema
