# ── AssetEra Environment Variables ──────────────────────────────────

# OpenAI API key (required for AI Advisor + Data Workbench LLM summaries)
OPENAI_API_KEY=sk-proj-...

# ── Storage Backend: choose S3 (preferred) OR PostgreSQL ────────────

# ── Option A: S3 + DuckDB (recommended, no free-tier limits) ────────
# Create an S3 bucket, then fill in:
DATA_BUCKET=assetera-data-prod
AWS_REGION=ap-south-1

# Static credentials (skip if using IAM role / instance profile):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=        # optional — only for temporary STS credentials

# ── Option B: PostgreSQL / Supabase (legacy fallback) ───────────────
# POSTGRES_URL=postgresql://postgres:[PASSWORD]@db.xxx.supabase.co:5432/postgres
# DATABASE_URL=           # alternative env var name for POSTGRES_URL

# ── Data Workbench settings (optional — sensible defaults built-in) ──
DATA_MAX_SYNC_MB=200          # files larger than this go through async worker
DATA_PROFILE_SAMPLE_ROWS=50000  # max rows used for profiling
DATA_QUERY_ROW_LIMIT=5000       # max rows returned by Ask Data queries
